# Environment variables for the thesis project
# ⚠️  NEVER commit this file to GitHub — it is in .gitignore

# LLM Provider (gemini | openai | anthropic)
LLM_PROVIDER=gemini

# Paste your Gemini API key here (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Uncomment if using OpenAI instead:
# OPENAI_API_KEY=your_openai_key_here

# Uncomment if using Anthropic instead:
# ANTHROPIC_API_KEY=your_anthropic_key_here
